# Copy to .env and fill in values

PORT=3000

# Secret the plugin must send in the Authorization header when connecting
PLUGIN_API_KEY=change-me-plugin-key

# Secret required for admin REST endpoints (kept as fallback for API/script access)
ADMIN_TOKEN=change-me-admin-token

# Initial admin user (only used if no users exist in database)
ADMIN_USER=
ADMIN_PASS=

# PostgreSQL connection string.
# Docker Compose sets this automatically; override here for local development.
DATABASE_URL=postgresql://liftoff:liftoff@localhost:5432/liftoff

# Comma-separated list of player nicks immune to idle kick (JMT-Bot is always immune)
IDLE_KICK_WHITELIST=
