# Copy to .env and fill in values

PORT=3000

# Secret the plugin must send in the Authorization header when connecting
PLUGIN_API_KEY=change-me-plugin-key

# Secret required for admin REST endpoints
ADMIN_TOKEN=change-me-admin-token

# Path to SQLite database file.
# When running in Docker use /app/data/competition.db (mapped to ./data/ volume).
# For local development ./competition.db is fine.
DB_PATH=/app/data/competition.db

# Comma-separated list of player nicks immune to idle kick (JMT-Bot is always immune)
IDLE_KICK_WHITELIST=
