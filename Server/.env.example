# Copy to .env and fill in values

PORT=3000

# Secret the plugin must send in the Authorization header when connecting
PLUGIN_API_KEY=change-me-plugin-key

# Secret required for admin REST endpoints (kept as fallback for API/script access)
ADMIN_TOKEN=change-me-admin-token

# Initial admin user (only used if no users exist in database)
ADMIN_USER=
ADMIN_PASS=

# PostgreSQL connection string.
# Docker Compose sets this automatically; override here for local development.
DATABASE_URL=postgresql://liftoff:liftoff@localhost:5432/liftoff

# Optional: Steam Web API key — enables author display name resolution when fetching
# Steam Workshop metadata. Without this, only the author's SteamID profile link is shown.
# Get a key at https://steamcommunity.com/dev/apikey
# STEAM_API_KEY=

# (DEPRECATED) Whitelist is now managed via the database / admin panel.
# If set, entries are migrated to the database on first startup and this var is ignored afterwards.
# IDLE_KICK_WHITELIST=
